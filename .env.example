# ─── Authentication ───────────────────────────────────────────────────────────

APP_PASSWORD=your-app-password

# Change these to invalidate all existing sessions (rotate if compromised)
SESSION_SECRET=your-random-hex-64chars
AUTH_SALT=your-random-hex-64chars

# Session lifetime in hours (default: 720 = 30 days)
# SESSION_TTL_HOURS=720

# ─── Server ───────────────────────────────────────────────────────────────────

PORT=3443

# TLS is handled by Caddy — no HTTPS on the server itself
ENABLE_HTTPS=false

# ─── Tunnel / Proxy ──────────────────────────────────────────────────────────

# No ngrok — traffic comes via SSH reverse tunnel → Caddy
TUNNEL_MODE=none

# Trust X-Forwarded-For headers from Caddy
TRUST_PROXY=true

# Your stable external domain (shown in startup banner and /health)
EXTERNAL_URL=https://ag.your-domain.com

# ─── SSH Tunnel ──────────────────────────────────────────────────────────────

# VPS connection details for the reverse SSH tunnel
SSH_USER=root
SSH_HOST=your-vps-hostname.com
SSH_REMOTE_PORT=8090
